#!/usr/bin/env zsh

#shellcheck shell=bash disable=2034,2206,2086,1091
ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="robbyrussell"
KEYTIMEOUT=1
DISABLE_AUTO_TITLE=true
DISABLE_MAGIC_FUNCTIONS=true

# needed for tmux called in function gw
export PATH="/usr/bin:/bin:/usr/sbin:/sbin:$PATH"
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"

# export TERM="xterm-256color"
export PYENV_ROOT="$HOME/.pyenv"
export TODO_DIR=$HOME/.todo

PATHS=(
  $HOME/bin
  $HOME/go/bin
  $HOME/.bun/bin
  $HOME/.local/bin
  $HOME/.luarocks/bin
  $HOME/.cargo/bin
  $HOME/.dotnet/tools
  $BREW_PREFIX/bin
  $BREW_PREFIX/sbin
  $PYENV_ROOT/bin
  /usr/local/bin
  /usr/local/sbin
  /usr/local/go/bin
  /snap/bin
  /usr/local/opt/{grep,coreutils,findutils}/libexec/gnubin
)

for i in "${PATHS[@]}"; do
  [[ -d "$i" ]] && [[ ! $PATH == *"$i"* ]] && PATH="$i:$PATH"
done

if [[ -z $plugins ]]; then
  plugins=(
    git
    autojump
    evalcache
    web-search
    zsh-vi-mode
    zsh-autosuggestions
    zsh-syntax-highlighting
  )
fi

autoload -Uz compinit
compinit -C

source $ZSH/oh-my-zsh.sh

# need to add the -M mode here or it will not work with zsh-vi-mode
# bindkey -M viins '^[|' zsh_gh_copilot_explain # bind Alt+shift+\ to explain
# bindkey -M viins '^[\' zsh_gh_copilot_suggest # bind Alt+\ to suggest

unset PATHS
unset plugins

# 3rd party completions
command -v kubectl >/dev/null 2>&1 && _evalcache kubectl completion zsh
command -v argo >/dev/null 2>&1 && _evalcache argo completion zsh
command -v gh >/dev/null 2>&1 && _evalcache gh completion -s zsh
command -v direnv >/dev/null 2>&1 && _evalcache direnv hook zsh
command -v fnm >/dev/null 2>&1 && _evalcache fnm env --use-on-cd --shell zsh

alias x="exit"
alias vi="nvim"
alias c="clear"
alias cls="clear"
alias td="todo.sh"
alias k="kubectl"
alias start=/mnt/c/Windows/explorer.exe

complete -F __start_kubectl k

killp() {
  kill -9 $(lsof -t -i :"$@")
}

colortest() {
  curl -sSLk -H "Cache-Control: no-cache, no-store" https://gist.githubusercontent.com/pwang2/77450beffe2d343c6c446a33a6df74f0/raw\?t=$(date +%s) | bash
}

strongpass() {
  if [[ $(uname) == "Darwin" && -x "$(command -v pbcopy)" ]]; then
    openssl rand -base64 14 | pbcopy
  elif [[ $(uname) == "Linux" && -x "$(command -v xclip)" ]]; then
    openssl rand -base64 14 | xclip -selection clipboard
  else
    openssl rand -base64 14
  fi
}

profile() {
  zmodload zsh/zprof
  source ~/.zshrc_shared
  zprof
}

gw() {
  local name="${1#.worktrees/}"
  local wt_path=".worktrees/$name"

  git worktree add "$wt_path"
  tmux new-window -n "$name" -c "$PWD/$wt_path"
  tmux split-window -h -c "$PWD/$wt_path"
  tmux select-pane -t 1
  tmux split-window -v -l 8 -c "$PWD/$wt_path"
  tmux select-pane -t 1
  tmux send-keys "nvim" Enter
  tmux select-pane -t 3
  tmux send-keys "oc" Enter
  tmux select-pane -t 1
}

gcmai() {
  local diff
  diff=$(git diff --cached)

  if [[ -z "$diff" ]]; then
    echo "No staged changes found. Use 'git add' first."
    return 1
  fi

  local msg
  msg=$(echo "$diff" | claude -p "Generate a concise git commit message for this diff. Output ONLY the commit message — no explanation, no backticks, no preamble. Use conventional commits format (feat/fix/refactor/chore/docs/test/style/perf). First line ≤72 chars. Add a blank line and bullet points for non-trivial changes.")

  if [[ -z "$msg" ]]; then
    echo "Failed to generate commit message."
    return 1
  fi

  echo "Generated message:"
  echo "─────────────────"
  echo "$msg"
  echo "─────────────────"
  echo ""

  read -r "?Commit with this message? [y/e/n] " choice
  case "$choice" in
  y | Y) git commit -m "$msg" ;;
  e | E)
    # Drop into $EDITOR to tweak
    local tmpfile
    tmpfile=$(mktemp /tmp/git_commit_msg.XXXXXX)
    echo "$msg" >"$tmpfile"
    ${EDITOR:-nvim} "$tmpfile"
    git commit -F "$tmpfile"
    rm -f "$tmpfile"
    ;;
  *) echo "Aborted." ;;
  esac
}
